{
  "name": "vscode-lythra",
  "displayName": "Lythra",
  "description": "Syntax highlighting for the Lythra programming language",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lythra",
        "aliases": [
          "Lythra",
          "lythra"
        ],
        "extensions": [
          ".lth",
          ".lthx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lythra",
        "scopeName": "source.lythra",
        "path": "./syntaxes/lythra.tmLanguage.json"
      }
    ]
  }
}