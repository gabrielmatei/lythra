# Lythra Phase 5 Demo: Caching

log "=== Initializing Caching Tests ==="
log ""

# First, ensure we start with a clean slate
forget all

log "--- TEST 1: The identical prompts normally cost API bandwidth ---"
let start_time_1 = vision<String> "say the word 'Apple'"
log "First Call: " + start_time_1

let start_time_2 = vision<String> "say the word 'Apple'"
log "Second Call (Bypassed Cache): " + start_time_2
log "(these took standard time to generate)"
log ""


log "--- TEST 2: Remember blocks cache identical prompts ---"
remember:
  log "[Running First Remembered Call... this will hit the LLM API]"
  let cached_1 = vision<String> "say the word 'Banana'"
  log "Cached 1 result: " + cached_1

  log "[Running Second Remembered Call... this should be INSTANT]"
  let cached_2 = vision<String> "say the word 'Banana'"
  log "Cached 2 result: " + cached_2

log ""


log "--- TEST 3: Clearing the cache ---"
forget all

remember:
  log "[Running Third Remembered Call... this hits the LLM API again because we forgot everything!]"
  let cached_3 = vision<String> "say the word 'Banana'"
  log "Cached 3 result: " + cached_3

log "=== Testing Complete ==="
