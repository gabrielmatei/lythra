{
  "name": "lythra",
  "version": "0.1.0",
  "bin": {
    "lythra": "./bin/lythra"
  },
  "description": "A modern AI-first scripting language for building robust, deterministic, and typed heuristic reasoning workflows.",
  "type": "module",
  "main": "dist/cli/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev docs --port 5000",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "dev": "tsc --watch"
  },
  "keywords": [
    "language",
    "llm",
    "scripting"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-istanbul": "^3.2.4",
    "mermaid": "^11.12.3",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^3.2.4",
    "vue": "^3.5.29"
  }
}
